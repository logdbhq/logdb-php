parameters:
    level: 8
    paths:
        - src
        - tests
    excludePaths:
        - tests/_fixtures/*
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        - identifier: missingType.iterableValue
        # Laravel + Monolog integrations may run without the optional dependency installed.
        - '#Class Illuminate\\.* not found#'
        # `RetryPolicy::execute` rethrows the inner exception type after exhausting retries —
        # PHPStan can't infer that the closure's thrown type bubbles out.
        - '#Dead catch - LogDB\\Errors\\LogDB(Timeout|Auth|Config)Error is never thrown in the try block.#'
        - '#Unreachable statement - code above always terminates.#'
